func _next_round() -> void:
	if not multiplayer.is_server():
		return

	# Режим ИИ: запрашиваем новый вопрос у ИИ
	if use_ai_questions:
		_request_next_ai_question()
		return

	# Обычный режим: используем предзагруженные
	current_round += 1
	answered_this_round.clear()

	var q_index := (current_round - 1) % _questions.size()
	var q_data: Dictionary = _questions[q_index]

	_broadcast_question.rpc(q_data["question"], current_round, q_data["answers"])
	_start_round_timer()


func _start_round_timer() -> void:
	if not multiplayer.is_server():
		return
	_round_timer.wait_time = ROUND_TIME
	_round_timer.start()
	_time_left = int(ROUND_TIME)
	_countdown_timer.start()
	_sync_timer.rpc(_time_left)


func _stop_timers() -> void:
	_round_timer.stop()
	_countdown_timer.stop()


func _on_countdown_tick() -> void:
	_time_left -= 1
	if _time_left < 0:
		_time_left = 0
	_sync_timer.rpc(_time_left)


func _on_round_timer_timeout() -> void:
	if not multiplayer.is_server():
		return
	print("[GameManager] Время вышло!")
	if quiz_mode:
		_end_quiz_round()
	else:
		_end_round_with_reveal()


