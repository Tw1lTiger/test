@rpc("any_peer", "reliable")
func submit_answer(word: String) -> void:
	if not multiplayer.is_server():
		return
	var sender_id := multiplayer.get_remote_sender_id()
	if sender_id == 0:
		sender_id = 1
	_process_answer(sender_id, word)


var validating_players: Array[int] = []

## Обработка ответа — ГИБРИДНАЯ проверка
func _process_answer(sender_id: int, word: String) -> void:
	if not NetworkManager.players.has(sender_id):
		return

	if answered_this_round.has(sender_id):
		_send_rejection(sender_id, "Вы уже ответили в этом раунде!")
		return

	if validating_players.has(sender_id):
		return # Игрок уже ждет проверки

	var trimmed := word.strip_edges()
	if trimmed.length() < MIN_WORD_LENGTH or trimmed.length() > MAX_WORD_LENGTH:
		_send_rejection(sender_id, "Слово: от %d до %d символов" % [MIN_WORD_LENGTH, MAX_WORD_LENGTH])
		return

	var regex := RegEx.new()
	regex.compile("^[а-яА-ЯёЁa-zA-Z\\-]+$")
	if not regex.search(trimmed):
		_send_rejection(sender_id, "Слово должно содержать только буквы")
		return

	var word_lower := trimmed.to_lower()

	# 1. Локальная проверка (быстрая)
	if _is_word_valid(word_lower):
		_accept_answer(sender_id, trimmed)
		return

	# 2. AI проверка (медленная)
	print("[GameManager] Локально не найдено. Спрашиваем ИИ про \"%s\"..." % trimmed)
	validating_players.append(sender_id)
	_notify_answer_checking.rpc(sender_id) # Показать спинеры
	
	# Асинхронный вызов
	var is_valid: bool = await _gemini_api.validate_word(current_question, trimmed)
	
	validating_players.erase(sender_id)
	
	# Мог ответить пока ждали?
	if answered_this_round.has(sender_id):
		return

	if is_valid:
		print("[GameManager] ИИ подтвердил: \"%s\" — это верно!" % trimmed)
		# Добавляем в валидные, чтобы других игроков (или этого) валидировать быстрее
		_current_valid_answers.append(word_lower)
		_accept_answer(sender_id, trimmed)
	else:
		print("[GameManager] ИИ отклонил: \"%s\"" % trimmed)
		_notify_answer_invalid.rpc(sender_id, trimmed, "Я не знаю такого слова в этой категории")


func _accept_answer(sender_id: int, word: String) -> void:
	answered_this_round[sender_id] = true
	print("[GameManager] ✅ Игрок %d: \"%s\" — принято (скрыто)!" % [sender_id, word])

	var distance: float = word.length() * DISTANCE_COEFF
	
	_notify_answer_accepted_private.rpc_id(sender_id, word)
	
	answered_this_round[sender_id] = {
		"word": word,
		"points": distance
	}

	if answered_this_round.size() >= NetworkManager.get_player_count():
		_end_round_with_reveal()


## Завершение раунда с раскрытием ответов
func _end_round_with_reveal() -> void:
	_stop_timers()
	
	# Формируем пакет результатов для отправки всем
	var round_results: Dictionary = {} # peer_id -> {word, new_height, added_points}
	
	for peer_id in answered_this_round:
		var data = answered_this_round[peer_id]
		if data is Dictionary: # Проверка на всякий случай
			var points: float = data["points"]
			var current_h: float = NetworkManager.players[peer_id].get("height", 0.0)
			var new_h: float = current_h + points
			
			# Обновляем на сервере
			NetworkManager.players[peer_id]["height"] = new_h
			
			round_results[peer_id] = {
				"word": data["word"],
				"new_height": new_h,
				"points": points
			}

	# Рассылаем результаты всем
	_broadcast_round_reveal.rpc(round_results)
	
	# Проверяем победителя
	var winner_id: int = -1
	var max_h: float = -1.0
	
	for peer_id in NetworkManager.players:
		var h: float = NetworkManager.players[peer_id].get("height", 0.0)
		if h >= finish_height and h > max_h:
			max_h = h
			winner_id = peer_id
			
	if winner_id != -1:
		var nick: String = NetworkManager.players[winner_id].get("nickname", "Игрок")
		_broadcast_winner.rpc(winner_id, nick)
		return

	# Пауза перед следующим раундом
	_broadcast_loading_status.rpc("📊 Подводим итоги...")
	await get_tree().create_timer(4.0).timeout
	_next_round()


func _send_rejection(peer_id: int, reason: String) -> void:
	if peer_id == 1:
		answer_rejected.emit(reason)
	else:
		_notify_rejection.rpc_id(peer_id, reason)


@rpc("authority", "reliable", "call_local")
func _notify_answer_invalid(peer_id: int, _word: String, reason: String) -> void:
	answer_invalid.emit(peer_id, _word, reason)


@rpc("authority", "reliable", "call_local")
func _notify_answer_accepted_private(word: String) -> void:
	# Этот сигнал может слушать UI_Manager чтобы показать "Ответ принят, ждем остальных"
	# Добавим сигнал answer_accepted в GameManager
	if not has_signal("answer_accepted"):
		add_user_signal("answer_accepted", [{"name": "word", "type": TYPE_STRING}])
	emit_signal("answer_accepted", word)


@rpc("authority", "reliable", "call_local")
func _broadcast_round_reveal(results: Dictionary) -> void:
	# results: peer_id -> {word, new_height, points}
	print("[GameManager] Раскрытие итогов раунда!")
	
	for peer_id in results:
		var data = results[peer_id]
		var word: String = data["word"]
		var h: float = data["new_height"]
		
		# Обновляем локальные данные о высоте
		if NetworkManager.players.has(peer_id):
			NetworkManager.players[peer_id]["height"] = h
			
		# Эмитим сигнал для UI (как будто ответил только что)
		player_answered.emit(peer_id, word, h)


@rpc("authority", "reliable")
func _notify_rejection(reason: String) -> void:
	answer_rejected.emit(reason)


@rpc("authority", "reliable", "call_local")
func _broadcast_winner(peer_id: int, nickname: String) -> void:
	player_won.emit(peer_id, nickname)
	if multiplayer.is_server():
		_change_state.rpc(GameState.GAME_OVER)


func return_to_lobby() -> void:
	if multiplayer.is_server():
		_stop_timers()
		for peer_id in NetworkManager.players:
			NetworkManager.players[peer_id]["height"] = 0.0
		_quiz_scores.clear()
		_quiz_answers.clear()
		_change_state.rpc(GameState.LOBBY)


func send_answer(word: String) -> void:
	if multiplayer.is_server():
		_process_answer(1, word)
	else:
		submit_answer.rpc_id(1, word)


