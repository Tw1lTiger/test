## Старт игры в режиме Викторины
func _start_quiz_game(_topic: String) -> void:
	if not multiplayer.is_server():
		return
	_gemini_api.clear_history()
	_quiz_scores.clear()
	_quiz_answers.clear()
	for peer_id in NetworkManager.players:
		_quiz_scores[peer_id] = 0

	_sync_quiz_settings.rpc(quiz_mode, quiz_round_time, quiz_total_rounds)
	_change_state.rpc(GameState.PLAYING)
	_request_next_quiz_question()


## Запросить следующий вопрос для викторины
func _request_next_quiz_question() -> void:
	if not multiplayer.is_server():
		return
	current_round += 1
	_quiz_answers.clear()
	round_number_changed.emit(current_round)
	_broadcast_loading_status.rpc("🧠 ИИ генерирует вопрос %d/%d..." % [current_round, quiz_total_rounds])
	if current_round > 1:
		await get_tree().create_timer(2.0).timeout
	var topic: String = custom_topic if custom_topic.strip_edges() != "" else "Общие знания"
	_gemini_api.generate_quiz_question(topic)


## Вопрос от ИИ получен
func _on_quiz_question_ready(data: Dictionary) -> void:
	if not multiplayer.is_server():
		return
	_quiz_current_question = data["question"]
	_quiz_current_key_points = data.get("key_points", [])
	print("[GameManager] ✅ Вопрос викторины: \"%s\"" % _quiz_current_question)
	_broadcast_quiz_question.rpc(_quiz_current_question, current_round, quiz_total_rounds)
	_start_quiz_timer()


func _start_quiz_timer() -> void:
	if not multiplayer.is_server():
		return
	_round_timer.wait_time = quiz_round_time
	_round_timer.start()
	_time_left = int(quiz_round_time)
	_countdown_timer.start()
	_sync_timer.rpc(_time_left)


## Отправка ответа в режиме викторины
func send_quiz_answer(answer_text: String) -> void:
	if multiplayer.is_server():
		_process_quiz_answer(1, answer_text)
	else:
		_submit_quiz_answer.rpc_id(1, answer_text)


@rpc("any_peer", "reliable")
func _submit_quiz_answer(answer_text: String) -> void:
	if not multiplayer.is_server():
		return
	var sender_id := multiplayer.get_remote_sender_id()
	if sender_id == 0:
		sender_id = 1
	_process_quiz_answer(sender_id, answer_text)


func _process_quiz_answer(sender_id: int, answer_text: String) -> void:
	if not NetworkManager.players.has(sender_id):
		return
	if _quiz_answers.has(sender_id):
		_send_rejection(sender_id, "Вы уже ответили в этом раунде!")
		return

	var trimmed := answer_text.strip_edges()
	if trimmed.length() < 2:
		_send_rejection(sender_id, "Ответ слишком короткий (минимум 2 символа)")
		return
	if trimmed.length() > 1000:
		trimmed = trimmed.left(1000)

	_quiz_answers[sender_id] = trimmed
	print("[GameManager] Студент %d ответил (%d символов)" % [sender_id, trimmed.length()])

	# Уведомляем студента, что ответ принят
	_notify_quiz_answer_accepted.rpc_id(sender_id)

	# Если все ответили — завершаем раунд
	if _quiz_answers.size() >= NetworkManager.get_player_count():
		_end_quiz_round()


## Завершение раунда викторины — отправляем все ответы на оценку ИИ
func _end_quiz_round() -> void:
	_stop_timers()
	if _quiz_answers.is_empty():
		_broadcast_loading_status.rpc("⚠️ Никто не ответил! Переходим к следующему вопросу...")
		await get_tree().create_timer(2.0).timeout
		if current_round >= quiz_total_rounds:
			_finish_quiz_game()
		else:
			_request_next_quiz_question()
		return

	_broadcast_loading_status.rpc("🤖 ИИ оценивает ответы...")
	_broadcast_quiz_evaluating.rpc()

	# Преобразуем для API: ключи как строки
	var answers_for_api: Dictionary = {}
	for peer_id in _quiz_answers:
		answers_for_api[str(peer_id)] = _quiz_answers[peer_id]

	_gemini_api.evaluate_answers(_quiz_current_question, _quiz_current_key_points, answers_for_api)


## Результаты оценки получены от ИИ
func _on_answers_evaluated(results: Dictionary) -> void:
	if not multiplayer.is_server():
		return

	print("[GameManager] Получены оценки от ИИ: %d студентов" % results.size())

	# Обновляем общие баллы
	for peer_id in results:
		var score: int = results[peer_id].get("score", 0)
		_quiz_scores[peer_id] = _quiz_scores.get(peer_id, 0) + score
		# Обновляем height для совместимости с отображением
		if NetworkManager.players.has(peer_id):
			NetworkManager.players[peer_id]["height"] = float(_quiz_scores[peer_id])

	# Рассылаем обновлённые данные об игроках (включая height/score), чтобы у всех обновился интерфейс
	NetworkManager._sync_players.rpc(NetworkManager.players)

	# Формируем данные для рассылки
	var broadcast_data: Dictionary = {}
	for peer_id in results:
		broadcast_data[peer_id] = {
			"score": results[peer_id].get("score", 0),
			"feedback": results[peer_id].get("feedback", ""),
			"weak_areas": results[peer_id].get("weak_areas", []),
			"explanation": results[peer_id].get("explanation", ""),
			"correct_answer": results[peer_id].get("correct_answer", ""),
			"topics_to_review": results[peer_id].get("topics_to_review", []),
			"answer": _quiz_answers.get(peer_id, ""),
			"total_score": _quiz_scores.get(peer_id, 0),
			"question": _quiz_current_question,
			"round": current_round,
			"total_rounds": quiz_total_rounds
		}

	_broadcast_quiz_round_results.rpc(broadcast_data)

	# Пауза перед следующим раундом
	await get_tree().create_timer(5.0).timeout

	if current_round >= quiz_total_rounds:
		_finish_quiz_game()
	else:
		_request_next_quiz_question()


## Финиш викторины
func _finish_quiz_game() -> void:
	var final_data: Dictionary = {}
	for peer_id in _quiz_scores:
		var nick: String = NetworkManager.players.get(peer_id, {}).get("nickname", "Студент")
		final_data[peer_id] = {
			"nickname": nick,
			"total_score": _quiz_scores[peer_id],
			"max_possible": quiz_total_rounds * 10
		}

	# Определяем победителя
	var best_id: int = -1
	var best_score: int = -1
	for peer_id in _quiz_scores:
		if _quiz_scores[peer_id] > best_score:
			best_score = _quiz_scores[peer_id]
			best_id = peer_id

	if best_id != -1:
		var nick: String = NetworkManager.players.get(best_id, {}).get("nickname", "Студент")
		_broadcast_quiz_finished.rpc(final_data, best_id, nick)
		_change_state.rpc(GameState.GAME_OVER)


# ==============================================================================
# РЕЖИМ ВИКТОРИНЫ — RPC
# ==============================================================================

@rpc("authority", "reliable", "call_local")
func _sync_quiz_settings(is_quiz: bool, round_time: float, total_rnds: int) -> void:
	quiz_mode = is_quiz
	quiz_round_time = round_time
	quiz_total_rounds = total_rnds
	print("[GameManager] Режим: %s, время: %.0fс, раундов: %d" % [
		"Викторина" if is_quiz else "Гонка слов", round_time, total_rnds
	])


@rpc("authority", "reliable", "call_local")
func _broadcast_quiz_question(question: String, round_num: int, total_rnds: int) -> void:
	_quiz_current_question = question
	current_round = round_num
	quiz_total_rounds = total_rnds
	quiz_question_received.emit(question)
	round_number_changed.emit(round_num)
	print("[GameManager] 📝 Раунд %d/%d: \"%s\"" % [round_num, total_rnds, question])


@rpc("authority", "reliable", "call_local")
func _notify_quiz_answer_accepted() -> void:
	quiz_answer_accepted.emit()


@rpc("authority", "reliable", "call_local")
func _broadcast_quiz_evaluating() -> void:
	quiz_evaluating.emit()


@rpc("authority", "reliable", "call_local")
func _broadcast_quiz_round_results(results: Dictionary) -> void:
	print("[GameManager] 📊 Результаты раунда получены")

	# Сохраняем в историю студента (на клиенте)
	var my_id := multiplayer.get_unique_id()
	if results.has(my_id):
		var my_data: Dictionary = results[my_id]
		StudentHistory.save_result({
			"date": Time.get_datetime_string_from_system(),
			"topic": custom_topic if custom_topic != "" else "Общие знания",
			"question": my_data.get("question", _quiz_current_question),
			"answer": my_data.get("answer", ""),
			"score": my_data.get("score", 0),
			"max_score": 10,
			"feedback": my_data.get("feedback", ""),
			"weak_areas": my_data.get("weak_areas", []),
			"explanation": my_data.get("explanation", ""),
			"correct_answer": my_data.get("correct_answer", ""),
			"topics_to_review": my_data.get("topics_to_review", []),
		})

	quiz_results_received.emit(results)


@rpc("authority", "reliable", "call_local")
func _broadcast_quiz_finished(final_data: Dictionary, winner_id: int, winner_nick: String) -> void:
	print("[GameManager] 🏆 Викторина закончена! Победитель: %s" % winner_nick)
	quiz_game_finished.emit(final_data)
	player_won.emit(winner_id, winner_nick)
