# Нечёткая проверка — Левенштейн + совпадение корня
# ==============================================================================

## Расстояние Левенштейна — количество правок (вставка/удаление/замена)
func _levenshtein(a: String, b: String) -> int:
	var la := a.length()
	var lb := b.length()
	if la == 0: return lb
	if lb == 0: return la

	# Одномерный массив для экономии памяти
	var prev: Array[int] = []
	prev.resize(lb + 1)
	for j in range(lb + 1):
		prev[j] = j

	for i in range(1, la + 1):
		var curr: Array[int] = []
		curr.resize(lb + 1)
		curr[0] = i
		for j in range(1, lb + 1):
			var cost := 0 if a[i - 1] == b[j - 1] else 1
			curr[j] = mini(mini(curr[j - 1] + 1, prev[j] + 1), prev[j - 1] + cost)
		prev = curr

	return prev[lb]


## Проверяет, подходит ли слово к списку допустимых ответов
## Использует: точное совпадение, Левенштейн (≤2 ошибки), совпадение корня (3+ букв)
func _is_word_valid(word: String) -> bool:
	for valid in _current_valid_answers:
		if word == valid:
			return true

		# Строгая проверка Левенштейна в зависимости от длины
		var len_valid := valid.length()
		var max_err := 0
		
		# Эвристика: чем длиннее слово, тем больше опечаток прощаем
		if len_valid <= 3:
			max_err = 0 # Кот != Кит (слишком короткие)
		elif len_valid <= 5:
			max_err = 1 # Допускаем 1 опечатку
		else:
			max_err = 2 # Допускаем 2 опечатки
			
		if absi(word.length() - len_valid) <= max_err:
			if _levenshtein(word, valid) <= max_err:
				return true
				
	return false


