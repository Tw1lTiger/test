# ==============================================================================
# GameManager.gd — Управление раундами, вопросами, проверкой ответов
# Вопросы генерируются ДО начала игры, проверка — ЛОКАЛЬНАЯ с нечётким сравнением
# ==============================================================================
extends Node

enum GameState { LOBBY, LOADING, PLAYING, ROUND_END, GAME_OVER }

signal state_changed(new_state: GameState)
signal question_received(question: String)
signal player_answered(peer_id: int, word: String, new_height: float)
signal player_won(peer_id: int, nickname: String)
signal answer_rejected(reason: String)
signal round_number_changed(round_num: int)
signal timer_updated(seconds_left: int)
signal answer_accepted(word: String)
signal answer_invalid(peer_id: int, word: String, reason: String)
signal answer_checking(peer_id: int)
signal loading_status(message: String)

## Сигналы для режима Викторины
signal quiz_question_received(question: String)
signal quiz_answer_accepted()
signal quiz_results_received(results: Dictionary)
signal quiz_game_finished(final_scores: Dictionary)
signal quiz_evaluating()

const DISTANCE_COEFF: float = 1.0  ## 1 буква = 1 очко
var finish_height: float = 300.0  ## Финиш на выбранное число очков
var custom_topic: String = ""
const MAX_WORD_LENGTH: int = 30
const MIN_WORD_LENGTH: int = 2
const ROUND_TIME: float = 30.0
## Макс. допустимое расстояние Левенштейна (кол-во ошибок)
const MAX_TYPO_DISTANCE: int = 2

## Режим Викторины
var quiz_mode: bool = false
var quiz_round_time: float = 60.0  ## Время на ответ в викторине (настраивается)
var quiz_total_rounds: int = 5     ## Количество раундов
var _quiz_answers: Dictionary = {}  ## peer_id -> текст ответа
var _quiz_scores: Dictionary = {}   ## peer_id -> total_score
var _quiz_current_key_points: Array = []
var _quiz_current_question: String = ""

var current_state: GameState = GameState.LOBBY
var current_question: String = ""
var current_round: int = 0
var answered_this_round: Dictionary = {}

## Предзагруженные вопросы
var _questions: Array = []
var _current_valid_answers: Array[String] = []

## Режим вопросов: true = ИИ, false = обычные
var use_ai_questions: bool = true

var _round_timer: Timer
var _countdown_timer: Timer
var _time_left: int = 0
var _gemini_api: Node


func _ready() -> void:
	var gemini_script := load("res://scripts/GeminiAPI.gd")
	_gemini_api = gemini_script.new()
	_gemini_api.name = "GeminiAPI"
	add_child(_gemini_api)
	_gemini_api.questions_ready.connect(_on_questions_ready)
	_gemini_api.single_question_ready.connect(_on_single_question_ready)
	_gemini_api.request_failed.connect(_on_gemini_failed)
	_gemini_api.quiz_question_ready.connect(_on_quiz_question_ready)
	_gemini_api.answers_evaluated.connect(_on_answers_evaluated)

	_round_timer = Timer.new()
	_round_timer.name = "RoundTimer"
	_round_timer.one_shot = true
	_round_timer.timeout.connect(_on_round_timer_timeout)
	add_child(_round_timer)

	_countdown_timer = Timer.new()
	_countdown_timer.name = "CountdownTimer"
	_countdown_timer.wait_time = 1.0
	_countdown_timer.timeout.connect(_on_countdown_tick)
	add_child(_countdown_timer)


func set_api_key(key: String) -> void:
	_gemini_api.set_api_key(key)


func set_question_mode(use_ai: bool) -> void:
	use_ai_questions = use_ai
	print("[GameManager] Режим вопросов: %s" % ("ИИ" if use_ai else "Обычные"))


# ==============================================================================
# Старт игры
# ==============================================================================

func start_game(topic: String = "", points: float = 300.0) -> void:
	if not multiplayer.is_server():
		return
	if NetworkManager.get_player_count() < 1:
		return

	_sync_game_settings.rpc(topic, points)

	for peer_id in NetworkManager.players:
		NetworkManager.players[peer_id]["height"] = 0.0

	current_round = 0
	_questions.clear()

	# Режим Викторины
	if quiz_mode:
		_start_quiz_game(topic)
		return

	if use_ai_questions:
		# Режим ИИ: сразу начинаем игру, генерируем по 1 вопросу
		_gemini_api.clear_history()
		_change_state.rpc(GameState.PLAYING)
		_request_next_ai_question()
	else:
		_change_state.rpc(GameState.LOADING)
		_broadcast_loading_status.rpc("📋 Загружаю обычные вопросы...")
		_load_fallback_questions()


## Запросить следующий вопрос у ИИ
func _request_next_ai_question() -> void:
	if not multiplayer.is_server():
		return
	current_round += 1
	answered_this_round.clear()
	_broadcast_loading_status.rpc("🧠 ИИ генерирует вопрос...")
	round_number_changed.emit(current_round)
	# Небольшая пауза между запросами, чтобы не перегружать API
	if current_round > 1:
		await get_tree().create_timer(2.0).timeout
	_gemini_api.generate_single_question()


## Один вопрос от ИИ получен
func _on_single_question_ready(question_data: Dictionary) -> void:
	if not multiplayer.is_server():
		return
	print("[GameManager] ✅ ИИ вопрос: \"%s\"" % question_data["question"])
	_broadcast_question.rpc(question_data["question"], current_round, question_data["answers"])
	_start_round_timer()


func _on_questions_ready(questions: Array) -> void:
	if not multiplayer.is_server():
		return

	_questions = questions
	_questions.shuffle()
	print("[GameManager] ✅ Загружено %d вопросов!" % _questions.size())

	var questions_data: Array = []
	for q in _questions:
		questions_data.append({"question": q["question"], "answers": q["answers"]})
	_sync_questions.rpc(questions_data)

	_broadcast_loading_status.rpc("✅ Загружено %d вопросов! Начинаем!" % _questions.size())
	await get_tree().create_timer(1.5).timeout
	_change_state.rpc(GameState.PLAYING)
	_next_round()


func _on_gemini_failed(error_msg: String) -> void:
	if not multiplayer.is_server():
		return

	push_warning("[GameManager] Ошибка Groq: %s" % error_msg)

	if use_ai_questions and current_state == GameState.PLAYING:
		# Ошибка посреди игры — переключаемся на запасные вопросы
		_broadcast_loading_status.rpc("⚠️ ИИ недоступен, переключаюсь на запасные...")
		use_ai_questions = false
		_questions = _get_fallback_questions()
		_questions.shuffle()
		var fallback_data: Array = []
		for q in _questions:
			fallback_data.append({"question": q["question"], "answers": q["answers"]})
		_sync_questions.rpc(fallback_data)
		await get_tree().create_timer(1.5).timeout
		_next_round()
		return

	# Ошибка при загрузке batch (обычные вопросы)
	_broadcast_loading_status.rpc("⚠️ ИИ недоступен, запасные вопросы...")
	_questions = _get_fallback_questions()
	_questions.shuffle()

	var fallback_sync_data: Array = []
	for q in _questions:
		fallback_sync_data.append({"question": q["question"], "answers": q["answers"]})
	_sync_questions.rpc(fallback_sync_data)

	await get_tree().create_timer(1.0).timeout
	_change_state.rpc(GameState.PLAYING)
	_next_round()


## Загрузка обычных (запасных) вопросов — без AI
func _load_fallback_questions() -> void:
	if not multiplayer.is_server():
		return

	_questions = _get_fallback_questions()
	_questions.shuffle()

	var questions_data: Array = []
	for q in _questions:
		questions_data.append({"question": q["question"], "answers": q["answers"]})
	_sync_questions.rpc(questions_data)

	_broadcast_loading_status.rpc("✅ Загружено %d вопросов! Начинаем!" % _questions.size())
	await get_tree().create_timer(1.0).timeout
	_change_state.rpc(GameState.PLAYING)
	_next_round()


